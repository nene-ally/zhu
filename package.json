{
  "name": "tauritavern",
  "private": true,
  "version": "2.1.1",
  "type": "module",
  "scripts": {
    "tauri": "tauri",
    "android": "tauri android",
    "ios": "tauri ios",
    "build": "pnpm run tauri:build",
    "dev": "pnpm run tauri:dev",
    "check": "pnpm run check:frontend && pnpm run check:types && pnpm run check:contracts",
    "check:frontend": "node scripts/check-frontend-guardrails.mjs",
    "check:frontend:baseline": "node scripts/check-frontend-guardrails.mjs --update-baseline",
    "check:types": "tsc -p tsconfig.host.json",
    "check:contracts": "pnpm run test:contracts",
    "test": "pnpm run test:contracts",
    "test:contracts": "node --test --test-concurrency=1 tests",
    "web:build": "rspack build --config rspack.config.js",
    "web:dev": "rspack build --config rspack.config.js --watch",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:portable": "node scripts/build-portable.mjs",
    "tauri:build:portable:skip-web": "node scripts/build-portable.mjs --skip-web-build",
    "android:dev": "tauri android dev",
    "android:build": "tauri android build",
    "ios:dev": "tauri ios dev",
    "ios:build": "tauri ios build",
    "ios:dev:policy": "node scripts/ios-policy.mjs dev",
    "ios:build:policy": "node scripts/ios-policy.mjs build",
    "fastools:build": "cargo build --release --manifest-path fastools/Cargo.toml",
    "fastools:run": "cargo run --manifest-path fastools/Cargo.toml"
  },
  "devDependencies": {
    "@rspack/cli": "^2.0.8",
    "@rspack/core": "^2.0.8",
    "@tauri-apps/cli": "^2.10.0",
    "@types/jquery": "^3.5.33",
    "@types/jquery-cropper": "^1.0.4",
    "@types/jquery.transit": "^0.9.33",
    "@types/jqueryui": "^1.12.24",
    "@types/lodash": "^4.17.24",
    "@types/node": "^20.19.43",
    "@types/select2": "^4.0.63",
    "@types/toastr": "^2.1.43",
    "es-module-lexer": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@adobe/css-tools": "^4.4.4",
    "@iconfu/svg-inject": "^1.2.3",
    "@mozilla/readability": "^0.6.0",
    "@popperjs/core": "^2.11.8",
    "bowser": "^2.12.1",
    "chevrotain": "^11.2.0",
    "diff-match-patch": "^1.0.5",
    "dompurify": "^3.4.2",
    "droll": "^0.2.1",
    "fflate": "^0.8.2",
    "fuse.js": "^7.1.0",
    "handlebars": "^4.7.9",
    "highlight.js": "^11.11.1",
    "js-sha256": "^0.11.1",
    "localforage": "^1.10.0",
    "lodash": "^4.18.1",
    "moment": "^2.30.1",
    "morphdom": "^2.7.7",
    "seedrandom": "^3.0.5",
    "showdown": "^2.1.0",
    "vue": "^3.5.33"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
